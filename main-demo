<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Memex — Three-Tier Cosmic Node Engine</title>
    <script type="text/javascript" src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
    <style>
        :root {
            --bg-desk: #141210;
            --panel-wood: #261f18;
            --glow-green: #52b788;
            --brass: #d4af37;
            --cyan: #00b4d8;
            --text-light: #e0d6c8;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-desk);
            font-family: 'Courier New', Courier, monospace;
            color: var(--text-light);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        header {
            background: #0b0a09;
            padding: 15px 20px;
            border-bottom: 2px solid var(--brass);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 { margin: 0; font-size: 1.2rem; color: var(--brass); letter-spacing: 2px; }

        .layout { display: flex; flex-grow: 1; height: calc(100vh - 55px); }
        .canvas-area { flex-grow: 1; position: relative; background: radial-gradient(circle, #1c1a16 0%, #080706 100%); }
        #network-graph { width: 100%; height: 100%; }

        .hud-panel {
            position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(11, 10, 9, 0.95);
            border: 1px solid var(--brass);
            padding: 15px;
            border-radius: 4px;
            max-width: 320px;
            pointer-events: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.6);
        }

        .hud-title { color: var(--brass); font-weight: bold; margin-bottom: 5px; text-transform: uppercase; }
        .hud-tier { font-size: 0.75rem; color: var(--cyan); margin-bottom: 8px; font-weight: bold; }
        .hud-body { font-size: 0.85rem; color: #b5ad9e; line-height: 1.4; }
    </style>
</head>
<body>

    <header>
        <h1>MEMEX // MULTI-TIER KINETIC REPOSITORY</h1>
        <div style="font-size: 0.8rem; color: var(--glow-green);">HIERARCHICAL PLANET STRUCTURE ONLINE</div>
    </header>

    <div class="layout">
        <div class="canvas-area">
            <div id="network-graph"></div>
            
            <!-- Contextual HUD -->
            <div class="hud-panel">
                <div class="hud-title" id="hud-name">Console Initialized</div>
                <div class="hud-tier" id="hud-tier">SYSTEM STANDBY</div>
                <div class="hud-body" id="hud-desc">Tap a golden Subject Sun to reveal Document Planets. Tap a Document Title Planet to branch out its Page Flag Moons.</div>
            </div>
        </div>
    </div>

    <script>
        let nodesDataset, edgesDataset, network;
        
        // Tier 1: Overarching Subject Suns
        const subjects = {
            'SUBJ_BALLISTICS': { id: 'SUBJ_BALLISTICS', label: 'BALLISTICS & ARCHERY', type: 'sun', desc: 'Master study tracking projectile systems, combat implementation, and mechanical weapon evolution.' }
        };

        // Tier 2: Document Planets (Orbiting the Suns)
        const documents = {
            'DOC_BOW': { id: 'DOC_BOW', parent: 'SUBJ_BALLISTICS', label: 'Book: Origins of the Bow', type: 'planet', desc: 'Comprehensive encyclopedia asset logging early ballistic staves and construction types.' },
            'DOC_ARROW': { id: 'DOC_ARROW', parent: 'SUBJ_BALLISTICS', label: 'Journal: Crusade Tactics', type: 'planet', desc: 'Military field dispatches tracking tactical release speeds and missile penetration parameters.' }
        };

        // Tier 3: Page Flag Moons (Branching off explicit Document Title Planets)
        const pageFlags = {
            'DOC_BOW': [
                { id: 'FLAG_BOW_P2', label: 'P.2: Horse Archers', desc: 'Annotated coordinate tracking operational movement mechanics of eastern units.' },
                { id: 'FLAG_BOW_P3', label: 'P.3: Turkish Design', desc: 'Stylus profile sketch mapping out the reflex curve elasticity parameters.' }
            ],
            'DOC_ARROW': [
                { id: 'FLAG_ARROW_P1', label: 'P.1: Penetration Formula', desc: 'Mathematical index tracking dynamic velocity metrics against heavy plate armor.' }
            ]
        };

        let expandedSuns = {};
        let expandedPlanets = {};

        function initNetwork() {
            nodesDataset = new vis.DataSet();
            edgesDataset = new vis.DataSet();

            // Render Tier 1: Suns
            Object.values(subjects).forEach(sun => {
                nodesDataset.add({
                    id: sun.id,
                    label: sun.label,
                    shape: 'dot',
                    size: 32,
                    font: { face: 'Courier New', color: '#fff', size: 15, bold: true },
                    color: { background: '#1c1712', border: '#d4af37', highlight: { background: '#d4af37', border: '#fff' } },
                    borderWidth: 3
                });
            });

            const container = document.getElementById('network-graph');
            const data = { nodes: nodesDataset, edges: edgesDataset };
            const options = {
                physics: {
                    barnesHut: { gravitationalConstant: -2000, centralGravity: 0.1, springLength: 90, springConstant: 0.05 }
                },
                interaction: { zoomView: true, dragView: true }
            };

            network = new vis.Network(container, data, options);

            network.on("click", function(params) {
                if (params.nodes.length > 0) {
                    handleNodeTap(params.nodes[0]);
                }
            });
        }

        function handleNodeTap(id) {
            // Click Tier 1: Subject Sun
            if (subjects[id]) {
                const sun = subjects[id];
                updateHUD(sun.label, "TIER 1: SUBJECT GROUP", sun.desc);
                if (expandedSuns[id]) collapseSun(id); else expandSun(id);
            } 
            // Click Tier 2: Document Planet
            else if (documents[id]) {
                const doc = documents[id];
                updateHUD(doc.label, "TIER 2: DOCUMENT SUN", doc.desc);
                if (expandedPlanets[id]) collapsePlanet(id); else expandPlanet(id);
            } 
            // Click Tier 3: Page Flag Moon
            else {
                let flag = null;
                Object.values(pageFlags).flat().forEach(f => { if(f.id === id) flag = f; });
                if (flag) {
                    updateHUD(`FLAG: ${flag.label}`, "TIER 3: PAGE ANCHOR MOON", `${flag.desc}\n\n[Action: Command desktop console or swipe to slide this page image into active view]`);
                }
            }
        }

        function updateHUD(name, tier, desc) {
            document.getElementById('hud-name').innerText = name;
            document.getElementById('hud-tier').innerText = tier;
            document.getElementById('hud-desc').innerText = desc;
        }

        function expandSun(sunId) {
            Object.values(documents).forEach(doc => {
                if (doc.parent === sunId) {
                    nodesDataset.add({
                        id: doc.id,
                        label: doc.label,
                        shape: 'dot',
                        size: 20,
                        font: { face: 'Courier New', color: 'var(--text-light)', size: 12, bold: true },
                        color: { background: '#0b0a09', border: 'var(--cyan)', highlight: { background: 'var(--cyan)', border: '#fff' } },
                        borderWidth: 2
                    });
                    edgesDataset.add({ id: `edge_${doc.id}`, from: sunId, to: doc.id, color: { color: 'var(--cyan)', opacity: 0.5 }, width: 2 });
                }
            });
            expandedSuns[sunId] = true;
        }

        function collapseSun(sunId) {
            Object.values(documents).forEach(doc => {
                if (doc.parent === sunId) {
                    if (expandedPlanets[doc.id]) collapsePlanet(doc.id);
                    if (nodesDataset.get(doc.id)) nodesDataset.remove(doc.id);
                    if (edgesDataset.get(`edge_${doc.id}`)) edgesDataset.remove(`edge_${doc.id}`);
                }
            });
            delete expandedSuns[sunId];
        }

        function expandPlanet(planetId) {
            const flags = pageFlags[planetId] || [];
            flags.forEach(flag => {
                nodesDataset.add({
                    id: flag.id,
                    label: flag.label,
                    shape: 'dot',
                    size: 11,
                    font: { face: 'Courier New', color: '#b5ad9e', size: 11 },
                    color: { background: '#141210', border: 'var(--glow-green)', highlight: { background: 'var(--glow-green)', border: '#fff' } },
                    borderWidth: 1.5
                });
                edgesDataset.add({ id: `edge_${flag.id}`, from: planetId, to: flag.id, color: { color: 'var(--glow-green)', opacity: 0.6 }, width: 1.5 });
            });
            expandedPlanets[planetId] = true;
        }

        function collapsePlanet(planetId) {
            const flags = pageFlags[planetId] || [];
            flags.forEach(flag => {
                if (nodesDataset.get(flag.id)) nodesDataset.remove(flag.id);
                if (edgesDataset.get(`edge_${flag.id}`)) edgesDataset.remove(`edge_${flag.id}`);
            });
            delete expandedPlanets[planetId];
        }

        window.onload = initNetwork;
    </script>
</body>
</html>
